rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    
    // Helper functions
    function isAuthenticated() {
      return request.auth != null;
    }
    
    function isRole(role) {
      return request.auth.token.role == role;
    }
    
    function isOfficialOrAdmin() {
      return request.auth.token.role in ['official', 'admin'];
    }
    
    function isOwner(uid) {
      return request.auth.uid == uid;
    }
    
    // Users collection
    match /users/{uid} {
      allow read: if isAuthenticated();
      allow create: if isAuthenticated() && request.auth.uid == uid;
      allow update: if isOwner(uid) || isRole('admin');
      
      // FCM tokens subcollection
      match /fcmTokens/{tokenId} {
        allow read, write: if isOwner(uid);
      }
    }
    
    // Issues collection
    match /issues/{issueId} {
      // Anyone authenticated can read issues
      allow read: if isAuthenticated();
      
      // Citizens can create issues (including anonymous where reportedBy may be null)
      allow create: if isAuthenticated()
        && (request.resource.data.reportedBy == request.auth.uid
            || request.resource.data.reportedBy == null
            || request.resource.data.reportedBy == 'demo_citizen');
      
      // Citizens can only update limited fields; officials can update everything
      allow update: if isAuthenticated() && (
        isOfficialOrAdmin() ||
        // Citizens can only update metrics.upvoteCount or verification
        (request.resource.data.diff(resource.data).affectedKeys()
           .hasOnly(['metrics.upvoteCount', 'updatedAt']))
      );
      
      // Agent results subcollection (written by Cloud Functions)
      match /agentResults/{agentId} {
        allow read: if isAuthenticated();
        allow write: if false;  // Only Cloud Functions write here
      }
    }
    
    // Verifications
    match /verifications/{verificationId} {
      allow read: if isAuthenticated();
      allow create: if isAuthenticated()
        && request.resource.data.verifiedBy == request.auth.uid;
      allow update, delete: if false;  // Verifications are immutable
    }
    
    // Departments (read-only for citizens)
    match /departments/{deptId} {
      allow read: if isAuthenticated();
      allow write: if isRole('admin');
    }
    
    // Executive summaries (officials and admins only)
    match /executiveSummaries/{summaryId} {
      allow read: if isOfficialOrAdmin();
      allow write: if false;  // Only Cloud Functions write
    }
    
    // Community stats (public read)
    match /communityStats/{wardId} {
      allow read: if true;  // Public — city health is public information
      allow write: if false;  // Only Cloud Functions write
    }
  }
}
